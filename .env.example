# Copy this file to .env and fill in your values
# cp .env.example .env

# Optional: Anthropic API key for AI-powered parsing of scanned PDFs and images
# Most users DON'T need this — CSV, Excel, and digital PDF parsing work without it.
# Only needed if you want to upload scanned paper statements or screenshot images.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Database location (defaults to ./backend/familybudget.db)
# DATABASE_URL=sqlite:///./familybudget.db
